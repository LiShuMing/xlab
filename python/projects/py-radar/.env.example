# Daily DB Radar Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Required: LLM API Configuration
# ============================================

# Your LLM API key (required)
# Example for DashScope: sk-xxxxxxxxxxxxxxxx
LLM_API_KEY=your-api-key-here

# LLM API base URL (optional, defaults to OpenAI)
# DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI: https://api.openai.com/v1
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM model name (optional, defaults to gpt-3.5-turbo)
# DashScope options: qwen-turbo, qwen-plus, qwen-max
# OpenAI options: gpt-3.5-turbo, gpt-4, gpt-4-turbo
LLM_MODEL=qwen-turbo

# LLM request timeout in seconds (optional, default: 300)
LLM_TIMEOUT=300

# ============================================
# Optional: Enhanced Data Sources
# ============================================

# Google Custom Search API (optional)
# Get from: https://developers.google.com/custom-search/v1/overview
GOOGLE_API_KEY=
GOOGLE_CX=

# NewsAPI (optional)
# Get from: https://newsapi.org/
NEWSAPI_KEY=

# ============================================
# Optional: Cloud Storage (for production)
# ============================================

# Alibaba Cloud OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=

# Database URL (optional, defaults to local file storage)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=

# Redis URL (optional, for caching and task queue)
# Format: redis://host:port/0
REDIS_URL=

# ============================================
# Application Settings
# ============================================

# Default language: en or zh
LANGUAGE=zh

# Maximum items to process per run
MAX_ITEMS=150

# Number of top items for summary
TOP_K=20

# Cache directory (optional)
CACHE_DIR=cache

# Output directory (optional)
OUTPUT_DIR=out
