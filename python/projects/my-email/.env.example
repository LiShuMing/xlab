# Gmail OAuth credentials (download from Google Cloud Console)
# Stored outside the project directory to avoid accidental commits
GMAIL_CREDENTIALS_FILE=~/.credentials/my-email/client_secret.json
GMAIL_TOKEN_FILE=~/.credentials/my-email/token.json

# Gmail filter query — adjust to match your newsletter senders
# Examples: Apache mailing lists, GitHub notifications, Substack, etc.
GMAIL_FILTER_QUERY=from:(*-dev@lists.apache.org) OR from:(announce@apache.org) OR label:newsletters

# Max messages to fetch per sync page
GMAIL_MAX_RESULTS=100

# HTTP timeout in seconds for Gmail API calls
GMAIL_TIMEOUT=60

# HTTP proxy for Gmail API (e.g., http://127.0.0.1:7890)
# Leave empty if you don't need a proxy
GMAIL_PROXY=

# SQLite database path
DB_PATH=data/my_email.db

# LLM backend (OpenAI-compatible)
# For Ollama: http://localhost:11434/v1  |  api_key = "ollama"
# For OpenAI: https://api.openai.com/v1  |  api_key = sk-...
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b
LLM_TIMEOUT=120

# Logging level: DEBUG | INFO | WARNING
LOG_LEVEL=INFO
