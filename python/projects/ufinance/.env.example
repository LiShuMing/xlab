# AI Lab Platform - Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# API Keys (at least one required)
# =============================================================================

# Qwen / DashScope (Alibaba Cloud)
# Get your key at: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Qwen Coding Plan (Optional - for coding tasks)
# Subscribe at: https://help.aliyun.com/zh/model-studio/coding-plan-quickstart
# Uses different API key (starts with sk-sp-xxx) and base URL
DASHSCOPE_CODING_API_KEY=your_coding_api_key_here
DASHSCOPE_CODING_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# OpenAI API
# Get your key at: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude API
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Custom Anthropic base URL (for proxy or enterprise endpoints)
# ANTHROPIC_BASE_URL=https://your-custom-endpoint.com

# =============================================================================
# LLM Configuration
# =============================================================================

# Default provider: "qwen" | "openai" | "anthropic"
DEFAULT_PROVIDER=qwen

# Default model name (provider-specific)
# Qwen options: qwen-turbo, qwen-plus, qwen-max, qwen-max-longcontext
# OpenAI options: gpt-3.5-turbo, gpt-4, gpt-4-turbo
DEFAULT_MODEL=qwen-turbo

# Model parameters
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=2000

# =============================================================================
# Embedding Configuration
# =============================================================================

# Embedding provider
EMBEDDING_PROVIDER=dashscope

# DashScope embedding model
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2

# =============================================================================
# RAG Configuration
# =============================================================================

# Text splitting parameters
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval parameters
TOP_K_RETRIEVAL=4
