# PyEgo MiniApp - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# Application Settings
# =============================================================================
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=change-me-to-a-random-string-min-32-chars
LOG_LEVEL=INFO

# =============================================================================
# Database Configuration
# =============================================================================
# Format: postgresql+asyncpg://user:password@host:port/database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=pyego
DATABASE_URL=postgresql+asyncpg://postgres:your-secure-password-here@db:5432/pyego
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# WeChat Mini Program
# =============================================================================
# Get these from WeChat MP Admin Console (https://mp.weixin.qq.com)
WECHAT_APP_ID=wx-your-app-id-here
WECHAT_APP_SECRET=your-app-secret-here

# =============================================================================
# LLM Configuration (Kimi / OpenAI)
# =============================================================================
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_API_KEY=your-kimi-api-key-here
LLM_MODEL=kimi-for-coding

# =============================================================================
# Embedding Configuration
# =============================================================================
# Must match the dimension in your database schema
# BAAI/bge-small-zh-v1.5 = 512 dimensions
# text-embedding-3-small = 1536 dimensions
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512

# =============================================================================
# Alibaba Cloud OSS (Object Storage)
# =============================================================================
# Get these from Alibaba Cloud Console (https://oss.console.aliyun.com)
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET_NAME=your-bucket-name
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_CUSTOM_DOMAIN=https://your-cdn-domain.com  # Optional

# =============================================================================
# JWT Authentication
# =============================================================================
# Generate a secure key: openssl rand -hex 32
JWT_SECRET_KEY=your-jwt-secret-key-min-32-characters-long
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# CORS Origins
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# =============================================================================
# Optional: S3 Backup (for automated backups)
# =============================================================================
# S3_BACKUP_BUCKET=your-backup-bucket-name

# =============================================================================
# Optional: Alert Webhook (DingTalk/WeChat)
# =============================================================================
# ALERT_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
